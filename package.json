{
  "name": "sendkit-workspace",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev:cli": "bun run packages/cli/src/index.ts",
    "dev:local-mcp": "bun run packages/local-mcp/src/index.ts",
    "dev:remote-mcp": "bun run apps/remote-mcp/src/index.ts",
    "release:pack:core": "bun run --filter @ckslabs/sendkit-core pack:dry",
    "release:pack:cli": "bun run --filter @ckslabs/sendkit pack:dry",
    "release:pack:local-mcp": "bun run --filter @ckslabs/sendkit pack:dry",
    "fmt": "oxfmt --write",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint --deny-warnings",
    "lint:fix": "oxlint --fix",
    "build:core": "bun run --filter @ckslabs/sendkit-core build",
    "build:cli": "bun run --filter @ckslabs/sendkit build",
    "build:local-mcp": "bun run --filter @ckslabs/sendkit-mcp build",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "oxfmt": "^0.59.0",
    "oxlint": "^1.74.0",
    "tsdown": "^0.22.7",
    "typescript": "^7.0.2"
  },
  "dependencies": {
    "unrun": "^0.3.1"
  }
}
